{
  "expo": {
    "name": "API TMDB",
    "slug": "api-tmdb",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1220"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "tmdbApiKey": "${TMDB_API_KEY}"
    }
  }
}
